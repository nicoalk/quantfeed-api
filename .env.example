# Get a free key at https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# Get a free key at https://www.marketaux.com/account/dashboard
MARKETAUX_API_KEY=

# Get a key from InFlow dashboard Configuration page (no separate sandbox environment)
INFLOW_API_KEY=
INFLOW_ENVIRONMENT=sandbox

# Local secret for MPP challenge HMAC binding. NOT issued by InFlow - generate your own
# random value (e.g. `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`)
# and keep it secret; it never leaves this server.
MPP_SECRET_KEY=

# Optional, defaults to 3000
PORT=3000
